# Copy to .env and fill in values for local dev. .env is git-ignored.

# Storage
DATA_DIR=./data
DB_PATH=./data/tutor.db

# LLM router config (TOML, see config/llm.toml)
LLM_CONFIG_PATH=./config/llm.toml

# Secrets — replace with `python -c "import secrets; print(secrets.token_urlsafe(32))"`
HMAC_SECRET=change-me
SESSION_SECRET=change-me

# Cloud provider keys (only needed for the roles you point at them in config/llm.toml)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Upload caps (bytes)
MAX_UPLOAD_EXCEL_BYTES=5242880
MAX_UPLOAD_IMAGE_BYTES=2097152
MAX_UPLOAD_PYTHON_BYTES=102400
